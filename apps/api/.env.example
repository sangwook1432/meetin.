# MEETIN API — 환경 변수 설정
# .env.example 을 복사해서 .env 로 사용하세요.
# 절대 .env 파일을 git에 커밋하지 마세요!
#
# cp .env.example .env

# ─── 앱 기본 ────────────────────────────────────────────────
APP_NAME=MEETIN API
ENV=local             # local | staging | production
DEBUG=true

# ─── DB ─────────────────────────────────────────────────────
# PostgreSQL 연결 문자열 (psycopg 드라이버)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/meetin

# DB 커넥션 풀 (운영 환경에서만 조정, 개발은 기본값 사용 가능)
# DB_POOL_SIZE=10       # 상시 유지 커넥션 수
# DB_MAX_OVERFLOW=20    # 피크 시 추가 허용
# DB_POOL_TIMEOUT=30    # 커넥션 대기 최대 초
# DB_POOL_RECYCLE=1800  # 30분마다 커넥션 재생성

# ─── JWT ────────────────────────────────────────────────────
# 최소 32자 이상 무작위 문자열로 교체하세요
JWT_SECRET=CHANGE_ME_random_secret_at_least_32_chars
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# ─── 전화번호 HMAC ───────────────────────────────────────────
# 전화번호 해시용 별도 비밀 키 (JWT_SECRET과 다르게 설정)
PHONE_HMAC_SECRET=CHANGE_ME_phone_hmac_secret_32_chars

# ─── 관리자 계정 ─────────────────────────────────────────────
# 가입 시 이 이메일로 등록하면 is_admin=True 자동 부여
ADMIN_EMAILS=admin@meetin.kr,dev@meetin.kr

# ─── CORS ────────────────────────────────────────────────────
# 콤마로 구분 (배포 시 프론트 도메인으로 교체)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 운영 예시:
# ALLOWED_ORIGINS=https://meetin.kr,https://www.meetin.kr

# ─── Toss Payments ──────────────────────────────────────────
# 테스트 키: https://developers.tosspayments.com/ 에서 발급
# 비워두면 mock 결제 모드로 동작 (개발 환경)
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

# ─── 카카오 알림톡 ───────────────────────────────────────────
# 카카오 비즈메시지 채널 설정
# 비워두면 콘솔 mock 로그로 대체 (개발 환경)
KAKAO_API_KEY=
KAKAO_SENDER_KEY=
# 아래 템플릿 코드는 카카오 채널 심사 후 발급된 코드로 교체
KAKAO_TPL_WAITING_CONFIRM=MEETIN_WAIT
KAKAO_TPL_CONFIRMED=MEETIN_CONF
KAKAO_TPL_REFUNDED=MEETIN_RFND
KAKAO_TPL_FORFEITED=MEETIN_FORF
KAKAO_TPL_REPLACEMENT=MEETIN_REPL

# ─── Sentry 에러 모니터링 ────────────────────────────────────
# https://sentry.io/ 에서 프로젝트 생성 후 DSN 입력
# 비워두면 Sentry 비활성화 (개발 환경)
SENTRY_DSN=
