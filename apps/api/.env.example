# ─────────────────────────────────────────
# MEETIN API — 환경변수 예시
# 실제 .env 파일을 이 파일을 복사해서 만드세요: cp .env.example .env
# ⚠️  .env 는 절대 git에 커밋하지 마세요
# ─────────────────────────────────────────

# 앱
APP_NAME=MEETIN API
ENV=local           # local | staging | production
DEBUG=true

# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/meetin

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# 전화번호 HMAC (전화번호 해시 저장용)
PHONE_HMAC_SECRET=change-me-to-another-long-random-secret

# 관리자 이메일 (콤마 구분)
ADMIN_EMAILS=admin@meetin.kr

# CORS 허용 origin (콤마 구분)
# 로컬: http://localhost:3000
# 프로덕션: https://meetin.kr,https://www.meetin.kr
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
